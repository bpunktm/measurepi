# Grafana-Benutzername fuer den Login ins Dashboard.
GF_SECURITY_ADMIN_USER=admin

# Grafana-Passwort fuer den Login ins Dashboard.
GF_SECURITY_ADMIN_PASSWORD=admin

# SNMP-v2c-Community fuer Switches, Gateway und UniFi-AP-Exporter.
SNMP_COMMUNITY=public

# WLAN-Interface des Pi, falls der wifi-exporter aktiv als Client-Sicht messen soll.
# Im Standardfall ist das wlan0.
WIFI_INTERFACE=wlan0

# Optionales Ziel fuer den externen ICMP-Test.
# Standardmaessig prueft der Stack damit, ob "das Internet" grundsaetzlich erreichbar ist.
INTERNET_PING_TARGET=1.1.1.1

# Optionales Ziel fuer den externen HTTP-Test.
# Standardmaessig wird ein leichtgewichtiges 204-Endpoint fuer Connectivity-Checks verwendet.
HTTP_CHECK_URL=https://connectivitycheck.gstatic.com/generate_204

# Optionaler Hostname fuer den DNS-Test des wifi-exporters.
# Nur relevant, wenn du die WLAN-Client-Sicht des Pi aktiv nutzt.
DNS_CHECK_HOST=connectivitycheck.gstatic.com

# Optionales Override fuer das lokale Gateway aus Sicht des Pi.
# Normalerweise nicht noetig, weil der wifi-exporter das Gateway aus der Routing-Tabelle liest.
GATEWAY_TARGET=
